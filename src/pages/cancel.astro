---
import Base from '../layouts/Base.astro';
---
<Base title="Checkout cancelled · Candle Atelier">
  <section class="max-w-xl mx-auto px-6 md:px-10 pt-24 pb-32 text-center">
    <h1 class="text-4xl md:text-5xl mb-6" style="color:var(--color-bone)">Checkout cancelled.</h1>
    <p class="leading-relaxed mb-10" style="color:var(--color-dust)">No charge was made. Your cart is still waiting for you.</p>
    <a href="/cart" class="inline-block px-6 py-3 bg-[color:var(--color-ember)] text-[color:var(--color-ink)] text-sm tracking-wide">Return to cart</a>
  </section>
</Base>
