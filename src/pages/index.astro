---
import Base from '../layouts/Base.astro';
import { supabase, type Product } from '../lib/supabase';

const { data } = await supabase
  .from('products')
  .select('*')
  .order('price_pence', { ascending: true });
const products = (data ?? []) as Product[];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Store',
  name: 'Candle Atelier',
  description: 'Hand-poured small-batch candles.',
  url: Astro.site?.toString() ?? 'https://candle-atelier.vercel.app',
};

const fmt = (p: number, c: string) =>
  new Intl.NumberFormat('en-GB', { style: 'currency', currency: c.toUpperCase() }).format(p / 100);
---
<Base
  title="Candle Atelier · Hand-poured candles"
  description="Hand-poured candles in small batches. Forest Balm, Sea Salt, Amber Wood, Fig & Cedar."
  schema={schema}
>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 md:px-10 pt-12 md:pt-20 pb-24 md:pb-32">
    <div class="grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-7">
        <div class="uppercase tracking-[0.4em] text-xs mb-6" style="color:var(--color-ember)">Winter Collection · MMXXV</div>
        <h1 class="text-5xl md:text-7xl leading-[1.02] mb-8" style="color:var(--color-bone)">
          Small flames.<br/>
          <span class="italic" style="color:var(--color-ember)">Slow light.</span>
        </h1>
        <p class="max-w-xl leading-relaxed md:text-lg" style="color:var(--color-dust)">
          Four candles, blended by hand from botanical and mineral notes — poured slowly into low tumblers of smoked glass. Each one, a quiet room of its own.
        </p>
        <div class="mt-10 flex items-center gap-5">
          <a href="/shop" class="px-6 py-3 bg-[color:var(--color-ember)] text-[color:var(--color-ink)] hover:opacity-90 transition-opacity tracking-wide text-sm">Shop the collection</a>
          <a href="#story" class="text-sm underline underline-offset-4 hover:text-[color:var(--color-ember)] transition-colors" style="color:var(--color-bone)">Our story</a>
        </div>
      </div>
      <div class="md:col-span-5 hidden md:block">
        <div class="aspect-[4/5] overflow-hidden relative">
          <img src="https://images.unsplash.com/photo-1636181093086-6c88b8781582?w=1000&auto=format&fit=crop" alt="Lit candle on dark surface" class="w-full h-full object-cover grayscale-[10%] contrast-[1.05]" />
          <div class="absolute inset-0" style="background:linear-gradient(180deg, transparent 40%, #050505 100%);"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Collection -->
  <section class="max-w-6xl mx-auto px-6 md:px-10 pb-24">
    <div class="flex items-end justify-between mb-10 border-b hairline pb-6">
      <h2 class="text-3xl md:text-4xl" style="color:var(--color-bone)">The Collection</h2>
      <a href="/shop" class="text-sm tracking-wide hover:text-[color:var(--color-ember)]" style="color:var(--color-dust)">All four →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-8">
      {products.map((p) => (
        <a href={`/product/${p.slug}`} class="group block">
          <div class="aspect-[3/4] overflow-hidden mb-5 relative">
            <img
              src={p.image_url ?? ''}
              alt={p.name}
              class="w-full h-full object-cover transition-all duration-700 group-hover:scale-[1.03] grayscale-[15%] group-hover:grayscale-0"
              loading="lazy"
            />
            <div class="absolute inset-0" style="background:linear-gradient(180deg, transparent 60%, rgba(5,5,5,0.7));"></div>
          </div>
          <div class="flex justify-between items-baseline">
            <h3 class="text-xl" style="color:var(--color-bone)">{p.name}</h3>
            <span class="text-sm" style="color:var(--color-ember)">{fmt(p.price_pence, p.currency)}</span>
          </div>
          <p class="text-xs mt-1 uppercase tracking-[0.2em]" style="color:var(--color-dust)">{p.notes}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Story -->
  <section id="story" class="max-w-6xl mx-auto px-6 md:px-10 py-24 border-t hairline">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <div class="uppercase tracking-[0.4em] text-xs mb-5" style="color:var(--color-ember)">Our atelier</div>
        <h2 class="text-4xl md:text-5xl leading-tight" style="color:var(--color-bone)">
          Four scents.<br/>One long winter.
        </h2>
      </div>
      <div class="md:col-span-7 md:text-lg leading-relaxed space-y-5" style="color:var(--color-dust)">
        <p>We began with a single wick and a notebook of remembered places — a rain-soaked pine wood, salt on a northern pier, amber warming in a cupped hand. Those notebooks became this collection.</p>
        <p>Every candle is blended and poured by hand in Yorkshire in batches of forty. We use unbleached cotton wicks, phthalate-free fragrance, and a coconut-rapeseed wax that burns clean for up to fifty hours.</p>
        <p>No marketing team. No seasonal drops. Just four quiet, considered candles — made to be lived with.</p>
      </div>
    </div>
  </section>

  <!-- Care -->
  <section id="care" class="max-w-6xl mx-auto px-6 md:px-10 py-24 border-t hairline">
    <div class="uppercase tracking-[0.4em] text-xs mb-5" style="color:var(--color-ember)">Candle care</div>
    <h2 class="text-3xl md:text-4xl mb-12" style="color:var(--color-bone)">Three quiet rules.</h2>
    <div class="grid md:grid-cols-3 gap-10">
      <div>
        <div class="font-serif text-5xl mb-4" style="color:var(--color-ember)">I.</div>
        <h3 class="text-lg mb-2" style="color:var(--color-bone)">The first burn</h3>
        <p class="text-sm leading-relaxed" style="color:var(--color-dust)">Let the wax pool reach the edge of the glass on the first burn — roughly two hours. This sets the memory of the candle.</p>
      </div>
      <div>
        <div class="font-serif text-5xl mb-4" style="color:var(--color-ember)">II.</div>
        <h3 class="text-lg mb-2" style="color:var(--color-bone)">Trim the wick</h3>
        <p class="text-sm leading-relaxed" style="color:var(--color-dust)">Before each lighting, trim to 4&nbsp;mm. A short wick is a steady flame.</p>
      </div>
      <div>
        <div class="font-serif text-5xl mb-4" style="color:var(--color-ember)">III.</div>
        <h3 class="text-lg mb-2" style="color:var(--color-bone)">Burn in hours</h3>
        <p class="text-sm leading-relaxed" style="color:var(--color-dust)">Never more than four hours at a time. Rest the candle, return to it.</p>
      </div>
    </div>
  </section>
</Base>
