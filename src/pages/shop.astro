---
import Base from '../layouts/Base.astro';
import { supabase, type Product } from '../lib/supabase';

const { data } = await supabase.from('products').select('*').order('price_pence');
const products = (data ?? []) as Product[];
const fmt = (p: number, c: string) =>
  new Intl.NumberFormat('en-GB', { style: 'currency', currency: c.toUpperCase() }).format(p / 100);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Candle Atelier collection',
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${Astro.site}product/${p.slug}`,
    name: p.name,
  })),
};
---
<Base title="The Collection · Candle Atelier" description="All four hand-poured candles." schema={schema}>
  <section class="max-w-6xl mx-auto px-6 md:px-10 pt-16 pb-24">
    <div class="uppercase tracking-[0.4em] text-xs mb-5" style="color:var(--color-ember)">The Collection</div>
    <h1 class="text-5xl md:text-6xl mb-16" style="color:var(--color-bone)">Four candles.</h1>
    <div class="grid sm:grid-cols-2 gap-x-8 gap-y-16">
      {products.map((p, i) => (
        <a href={`/product/${p.slug}`} class="group block">
          <div class="aspect-[4/5] overflow-hidden mb-5 relative">
            <img src={p.image_url ?? ''} alt={p.name} class="w-full h-full object-cover transition-all duration-700 group-hover:scale-[1.03] grayscale-[12%] group-hover:grayscale-0" loading="lazy" />
            <div class="absolute inset-0" style="background:linear-gradient(180deg, transparent 55%, rgba(5,5,5,0.6));"></div>
            <span class="absolute top-4 left-4 font-serif text-xl" style="color:var(--color-ember)">0{i + 1}</span>
          </div>
          <div class="flex justify-between items-baseline">
            <h2 class="text-2xl" style="color:var(--color-bone)">{p.name}</h2>
            <span class="text-sm" style="color:var(--color-ember)">{fmt(p.price_pence, p.currency)}</span>
          </div>
          <p class="text-xs mt-2 uppercase tracking-[0.25em]" style="color:var(--color-dust)">{p.notes}</p>
          <p class="mt-3 text-sm leading-relaxed" style="color:var(--color-dust)">{p.description}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
