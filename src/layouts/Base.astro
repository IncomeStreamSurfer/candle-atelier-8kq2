---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  schema?: Record<string, any>;
}

const {
  title,
  description = 'Hand-poured candles in small batches. Forest Balm, Sea Salt, Amber Wood, Fig & Cedar — delivered from the Candle Atelier studio.',
  image = '/og.svg',
  canonical,
  schema,
} = Astro.props;

const url = canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'https://candle-atelier.vercel.app').toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Ctext y='50' font-size='52'%3E%E2%9C%A6%3C/text%3E%3C/svg%3E" />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body>
    <header class="relative z-10">
      <div class="max-w-6xl mx-auto px-6 md:px-10 py-6 md:py-8 flex items-center justify-between">
        <a href="/" class="flex flex-col leading-none">
          <span class="font-serif text-2xl md:text-3xl text-bone tracking-wide" style="color:var(--color-bone)">Candle Atelier</span>
          <span class="text-[10px] md:text-xs uppercase tracking-[0.35em]" style="color:var(--color-dust)">Hand-poured · est. MMXXV</span>
        </a>
        <nav class="flex items-center gap-6 md:gap-8 text-sm">
          <a href="/shop" class="hover:text-[color:var(--color-ember)] transition-colors">Shop</a>
          <a href="/#story" class="hidden sm:inline hover:text-[color:var(--color-ember)] transition-colors">Story</a>
          <a href="/cart" class="hover:text-[color:var(--color-ember)] transition-colors">
            Cart <span id="cart-count" class="ml-1 text-[color:var(--color-ember)]">(0)</span>
          </a>
        </nav>
      </div>
      <div class="border-t hairline"></div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-32">
      <div class="border-t hairline"></div>
      <div class="max-w-6xl mx-auto px-6 md:px-10 py-14 grid md:grid-cols-3 gap-10 text-sm" style="color:var(--color-dust)">
        <div>
          <div class="font-serif text-xl mb-3" style="color:var(--color-bone)">Candle Atelier</div>
          <p class="leading-relaxed">Hand-poured, small-batch candles blended from botanical and mineral notes. Made slowly, on purpose.</p>
        </div>
        <div>
          <div class="uppercase tracking-[0.3em] text-xs mb-4" style="color:var(--color-bone)">Shop</div>
          <ul class="space-y-2">
            <li><a href="/product/forest-balm" class="hover:text-[color:var(--color-ember)]">Forest Balm</a></li>
            <li><a href="/product/sea-salt" class="hover:text-[color:var(--color-ember)]">Sea Salt</a></li>
            <li><a href="/product/amber-wood" class="hover:text-[color:var(--color-ember)]">Amber Wood</a></li>
            <li><a href="/product/fig-cedar" class="hover:text-[color:var(--color-ember)]">Fig &amp; Cedar</a></li>
          </ul>
        </div>
        <div>
          <div class="uppercase tracking-[0.3em] text-xs mb-4" style="color:var(--color-bone)">Atelier</div>
          <ul class="space-y-2">
            <li><a href="/#story" class="hover:text-[color:var(--color-ember)]">Our story</a></li>
            <li><a href="/#care" class="hover:text-[color:var(--color-ember)]">Candle care</a></li>
            <li><a href="mailto:hello@candleatelier.studio" class="hover:text-[color:var(--color-ember)]">Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t hairline">
        <div class="max-w-6xl mx-auto px-6 md:px-10 py-6 text-xs flex flex-col md:flex-row justify-between gap-2" style="color:var(--color-dust)">
          <div>© {new Date().getFullYear()} Candle Atelier · Hand-poured in small batches.</div>
          <div>Shipping within 2 working days · Free over £60</div>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        function readCart() {
          try { return JSON.parse(localStorage.getItem('ca-cart') || '[]'); } catch (e) { return []; }
        }
        function count() {
          return readCart().reduce((n, i) => n + (i.quantity || 0), 0);
        }
        function render() {
          var el = document.getElementById('cart-count');
          if (el) el.textContent = '(' + count() + ')';
        }
        window.addEventListener('storage', render);
        window.addEventListener('ca-cart-updated', render);
        render();
      })();
    </script>
  </body>
</html>
